@prefix dhc: <https://digitalhome.cloud/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:  <http://example.org/> .

ex:de-socket-bad a dhc:Circuit ;
  dhc:hasCircuitType dhc:CircuitType_Socket ;
  dhc:governedBy     dhc:Norm_DINVDE0100 ;
  dhc:maxPoints      "8"^^xsd:integer ;
  dhc:ratedCurrent   "16"^^xsd:decimal ;
  dhc:crossSection   "1.5"^^xsd:decimal .
