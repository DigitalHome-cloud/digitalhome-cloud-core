@prefix dhc: <https://digitalhome.cloud/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:  <http://example.org/> .

ex:gb-ring a dhc:Circuit ;
  dhc:hasCircuitType dhc:CircuitType_Socket ;
  dhc:governedBy     dhc:Norm_BS7671 ;
  dhc:ratedCurrent   "32"^^xsd:decimal ;
  dhc:crossSection   "2.5"^^xsd:decimal ;
  dhc:hasProtection  ex:rcbo-1 .

ex:rcbo-1 a dhc:ProtectionDevice .
