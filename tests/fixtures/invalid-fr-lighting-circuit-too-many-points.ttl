@prefix dhc: <https://digitalhome.cloud/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:  <http://example.org/> .

ex:fr-lighting-bad a dhc:Circuit ;
  dhc:hasCircuitType dhc:CircuitType_Lighting ;
  dhc:governedBy     dhc:Norm_NFC15100 ;
  dhc:maxPoints      "12"^^xsd:integer ;
  dhc:ratedCurrent   "10"^^xsd:decimal ;
  dhc:crossSection   "1.5"^^xsd:decimal .
