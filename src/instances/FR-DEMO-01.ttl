home:GAR_Mur1
  a dhc:Wall ;
  dhc:name "Mur extérieur garage" ;
  dhc:material "Parpaings 20x20x50" .

home:Isolation_Toit
  a dhc:Insulation ;
  dhc:name "Isolation toiture" ;
  dhc:material "Laine minérale 2x100mm croisée" .

home:Isolation_Combles
  a dhc:Insulation ;
