# ============================================================
# FR-DEMO-01 — Pavillon Rue des Cigales, Morsang-sur-Seine
#
# Complete ABox derived from the architectural and electrical
# plans of a 2-story French residential house built on the
# Lyonnaise des Eaux water treatment site (parcelle AN 71).
#
# Electrical installation per NF C 15-100.
# Supply contract: EDF 230V mono 9 kVA / 45 A, régime TT.
# ============================================================


# ════════════════════════════════════════════════════════════
# 1. REAL ESTATE
# ════════════════════════════════════════════════════════════

home:FR-DEMO-01
  a dhc:RealEstate ;
  dhc:smartHomeId "FR-DEMO-01" ;
  dhc:name "Pavillon Rue des Cigales" ;
  dhc:description "Pavillon de fonction pour un technicien de la Lyonnaise des Eaux et sa famille, construit sur le site de production d'eau potable de Morsang-sur-Seine (parcelle AN 71, Rue des Cigales)." ;
  dhc:hasArea home:Batiment ;
  dhc:hasArea home:Exterieur ;
  dhc:hasPlumbingSystem home:EauVille ;
  dhc:hasNetworkSegment home:ReseauLocal .


