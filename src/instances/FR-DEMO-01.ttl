# ════════════════════════════════════════════════════════════
# 4. ELECTRICAL — DELIVERY CHAIN (NFC 14-100)
# ════════════════════════════════════════════════════════════

home:LivraisonEnergie
  a dhc:EnergyDelivery ;
  dhc:name "Alimentation réseau Enedis" ;
  dhc:energyProviderName "Enedis (EDF)" ;
  dhc:currentType "SinglePhase" ;
  dhc:neutralSystem "TT" ;
  dhc:contractedPowerKVA 9.0 ;
  dhc:feeds home:Compteur .

home:Compteur
  a dhc-nfc14100:NF14EnergyMeter ;
  dhc:name "Compteur Linky" ;
  dhc:description "Coffret EDF en limite de propriété (chemin des Îles)" ;
  dhc:feeds home:AGCP .

home:AGCP
  a dhc-nfc14100:NF14EmergencyDisconnect ;
  dhc:name "Disjoncteur de branchement 30-60A / 500mA" ;
  dhc:description "Réf. 805030 AEM230/60, interrupteur différentiel instantané 2P, dans le garage" ;
  dhc:ratedCurrent 45.0 ;
  dhc:feeds home:TableauPrincipal .

home:CableAlimentation
  a dhc:WiringSegment ;
  dhc:name "Câble d'alimentation coffret EDF → tableau" ;
  dhc:description "2x16mm² Cu dans fourreau souterrain ø80mm, profondeur 0.85m" ;
  dhc:crossSection 16.0 .

home:GTL
  a dhc-nfc15100:GTL ;
  dhc:name "GTL (Gaine Technique Logement)" ;
  dhc:locatedIn home:Garage .


