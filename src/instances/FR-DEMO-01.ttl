home:SEJ_Mur1
  a dhc:Wall ;
  dhc:name "Mur extérieur séjour" ;
  dhc:material "Briques alvéolées 20x20x50 + isolation laine minérale 100+10mm" .

home:SEJ_Fenetre1
  a dhc:Window ;
  dhc:name "Fenêtre séjour 1" ;
  dhc:material "PVC double vitrage 4-16-4 argon basse émissivité" ;
  dhc:uValue 1.1 .

home:SEJ_Fenetre2
  a dhc:Window ;
  dhc:name "Fenêtre séjour 2" ;
  dhc:material "PVC double vitrage 4-16-4 argon basse émissivité" ;
