# ════════════════════════════════════════════════════════════
# VIEW: compliance
# ════════════════════════════════════════════════════════════

dhc:Norm a owl:Class ;
    rdfs:label "Norm"@en ;
    rdfs:comment "A national standard, regulation, or best practice. A Norm has one or more NormEditions, each representing a specific revision with its own C-Box SHACL shape file."@en .

dhc:Norm_NFC14100 a dhc:Norm ;
    rdfs:label "NF C 14-100"@en ;
    rdfs:comment "Energy delivery from provider to main board (France). Covers the connection between the public distribution network and the origin of the private installation."@en ;
    dhc:hasEdition dhc:NormEdition_NFC14100_2021 ;
    dhc:latestEdition dhc:NormEdition_NFC14100_2021 ;
    dhc:normCategory "Regulation" ;
    dhc:normCountry "FR" ;
    dhc:normDomain "electrical" ;
    dhc:normId "nfc14100" ;
    dhc:normWeight 1.0 .

dhc:Norm_NFC15100 a dhc:Norm ;
    rdfs:label "NF C 15-100"@en ;
    rdfs:comment "Residential and commercial low-voltage electrical installation (France). The primary norm governing circuit design, protection, wiring, and zone-specific requirements (bathrooms, pools, kitchens, etc.)."@en ;
    dhc:hasEdition dhc:NormEdition_NFC15100_2002,
        dhc:NormEdition_NFC15100_2015,
        dhc:NormEdition_NFC15100_2024 ;
    dhc:latestEdition dhc:NormEdition_NFC15100_2024 ;
    dhc:normCategory "Regulation" ;
    dhc:normCountry "FR" ;
    dhc:normDomain "electrical" ;
    dhc:normId "nfc15100" ;
    dhc:normWeight 1.0 .

dhc:hasEdition a owl:ObjectProperty ;
    rdfs:label "has edition"@en ;
    rdfs:comment "Links a Norm to one of its editions."@en ;
    rdfs:domain dhc:Norm ;
    rdfs:range dhc:NormEdition .

dhc:latestEdition a owl:ObjectProperty ;
    rdfs:label "latest edition"@en ;
    rdfs:comment "Points from a Norm to its currently active edition. The compliance engine uses this for gap analysis against the latest rules."@en ;
    rdfs:domain dhc:Norm ;
    rdfs:range dhc:NormEdition .

dhc:normCategory a owl:DatatypeProperty ;
    rdfs:label "norm category"@en ;
    rdfs:comment "One of: Regulation, Standard, BestPractice."@en ;
    rdfs:domain dhc:Norm ;
    rdfs:range xsd:string .

dhc:normCountry a owl:DatatypeProperty ;
    rdfs:label "norm country"@en ;
    rdfs:comment "ISO 3166-1 alpha-2 country code (e.g. 'FR')."@en ;
    rdfs:domain dhc:Norm ;
    rdfs:range xsd:string .

dhc:normDomain a owl:DatatypeProperty ;
    rdfs:label "norm domain"@en ;
    rdfs:comment "Technical domain: electrical, plumbing, heating, building."@en ;
    rdfs:domain dhc:Norm ;
    rdfs:range xsd:string .

dhc:normId a owl:DatatypeProperty ;
    rdfs:label "norm ID"@en ;
    rdfs:comment "Short stable identifier matching the C-Box directory name (e.g. 'nfc15100')."@en ;
    rdfs:domain dhc:Norm ;
    rdfs:range xsd:string .

dhc:normWeight a owl:DatatypeProperty ;
    rdfs:label "norm weight"@en ;
    rdfs:comment "1.0 = mandatory, 0.5 = recommended, 0.2 = optional."@en ;
    rdfs:domain dhc:Norm ;
    rdfs:range xsd:decimal .

