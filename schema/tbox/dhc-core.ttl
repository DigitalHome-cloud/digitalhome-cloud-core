@prefix brick:   <https://brickschema.org/schema/Brick#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dhc:     <https://digitalhome.cloud/ontology#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rec:     <https://w3id.org/rec#> .
@prefix s223:    <http://data.ashrae.org/standard223#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# ============================================================
# DigitalHome.Cloud Core Ontology — v3 (T-Box, domain extension)
#
# Pure domain layer over Brick + REC + ASHRAE 223P.
#   - dhc: classes that extend the three external standards
#   - dhc: object and data properties
#   - R-Box axioms and enum instances
#
# UI/UX annotations (designView, blockly*, @de/@fr labels) live
# in dhc-app-metadata.ttl — never here.
#
# Populate via py-tools/ontology_explorer.py option [4]
# (promote class from schema/draft/* into this file).
# ============================================================

<https://digitalhome.cloud/ontology>
    a owl:Ontology ;
    rdfs:label "DigitalHome.Cloud Core Ontology"@en ;
    dcterms:creator "D-LAB-5 / DigitalHome.Cloud" ;
    dcterms:description "Domain extension layer over Brick, REC, ASHRAE 223P. T-Box only."@en ;
    dcterms:license <https://opensource.org/licenses/MIT> ;
    owl:imports <https://brickschema.org/schema/Brick>,
                <https://w3id.org/rec> ;
    owl:versionInfo "3.0.0" .


# ════════════════════════════════════════════════════════════
# VIEW: governance
# ════════════════════════════════════════════════════════════


# ════════════════════════════════════════════════════════════
# VIEW: spatial
# ════════════════════════════════════════════════════════════

dhc:DigitalHome a owl:Class ;
    rdfs:label "Digital Home"@en ;
    rdfs:comment "The tenant boundary of a smart home digital twin. A physical property (house, apartment, land with buildings) managed as a single unit with shared IoT edge, power grid, and governance. Extends rec:Site."@en ;
    rdfs:subClassOf rec:Site .

dhc:createdAt a owl:DatatypeProperty ;
    rdfs:label "Created at"@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:dateTime .

dhc:createdBy a owl:ObjectProperty ;
    rdfs:label "Created by"@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range rec:Agent .

dhc:creationStatus a owl:DatatypeProperty ;
    rdfs:label "Creation status"@en ;
    rdfs:comment "One of: draft | active | archived."@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:string .

dhc:geocodeVerified a owl:DatatypeProperty ;
    rdfs:label "Geocode verified"@en ;
    rdfs:comment "True if lat/lng come from a provider geocode call."@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:boolean .

dhc:hasChargingStation a owl:ObjectProperty ;
    rdfs:label "has charging station"@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range brick:Electric_Vehicle_Charging_Station .

dhc:hasElectricVehicle a owl:ObjectProperty ;
    rdfs:label "has electric vehicle"@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range dhc:ElectricVehicle .

dhc:hasVehicle a owl:ObjectProperty ;
    rdfs:label "has vehicle"@en ;
    rdfs:comment "Links a DigitalHome to a vehicle associated with the property. Replaces dhc:hasElectricVehicle with broader scope."@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range dhc:Vehicle .

dhc:isDemo a owl:DatatypeProperty ;
    rdfs:label "Is demo"@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:boolean .

dhc:placeId a owl:DatatypeProperty ;
    rdfs:label "Place ID"@en ;
    rdfs:comment "Map provider's stable place identifier."@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:string .

dhc:placeIdProvider a owl:DatatypeProperty ;
    rdfs:label "Place ID provider"@en ;
    rdfs:comment "Provider: 'google' | 'amazon-location' | 'manual'."@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:string .

dhc:preferredLanguage a owl:DatatypeProperty ;
    rdfs:label "Preferred language"@en ;
    rdfs:comment "BCP-47 tag: 'en', 'de', 'fr'."@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:string .

dhc:smartHomeId a owl:DatatypeProperty ;
    rdfs:label "SmartHome ID"@en ;
    rdfs:comment "Tenant partition key. Format: {country}-{zip}-{street3}{number}-{nn} e.g. DE-80331-MAR12-01."@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:string .

dhc:updatedAt a owl:DatatypeProperty ;
    rdfs:label "Updated at"@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:dateTime .


# ════════════════════════════════════════════════════════════
# VIEW: building
# ════════════════════════════════════════════════════════════


