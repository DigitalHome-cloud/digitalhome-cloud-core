@prefix brick:   <https://brickschema.org/schema/Brick#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dhc:     <https://digitalhome.cloud/ontology#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rec:     <https://w3id.org/rec#> .
@prefix s223:    <http://data.ashrae.org/standard223#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# ============================================================
# DigitalHome.Cloud Core Ontology — v3 (T-Box, domain extension)
#
# Pure domain layer over Brick + REC + ASHRAE 223P.
#   - dhc: classes that extend the three external standards
#   - dhc: object and data properties
#   - R-Box axioms and enum instances
#
# UI/UX annotations (designView, blockly*, @de/@fr labels) live
# in dhc-app-metadata.ttl — never here.
#
# Populate via py-tools/ontology_explorer.py option [4]
# (promote class from schema/draft/* into this file).
# ============================================================

<https://digitalhome.cloud/ontology>
    a owl:Ontology ;
    rdfs:label "DigitalHome.Cloud Core Ontology"@en ;
    dcterms:creator "D-LAB-5 / DigitalHome.Cloud" ;
    dcterms:description "Domain extension layer over Brick, REC, ASHRAE 223P. T-Box only."@en ;
    dcterms:license <https://opensource.org/licenses/MIT> ;
    owl:imports <https://brickschema.org/schema/Brick>,
                <https://w3id.org/rec> ;
    owl:versionInfo "3.0.0" .

# ════════════════════════════════════════════════════════════
# VIEW: governance
# ════════════════════════════════════════════════════════════

dhc:NormEdition a owl:Class ;
    rdfs:label "Norm Edition"@en ;
    rdfs:comment "A specific version/revision of a Norm (e.g. NF C 15-100:2015, NF C 15-100:2024). Each edition has a corresponding C-Box SHACL shape file. New editions are not retroactive — existing installations remain governed by the edition they were built under."@en .

dhc:User a owl:Class ;
    rdfs:label "Application User"@en ;
    rdfs:comment "A major subdivision of a property (e.g. main building, annex, garden). No direct REC equivalent; extends rec:Architecture."@en ;
    rdfs:subClassOf rec:Person .

dhc:NormEdition_NFC14100_2021 a dhc:NormEdition ;
    rdfs:label "NF C 14-100:2021"@en ;
    rdfs:comment "Current edition of NF C 14-100."@en ;
    dhc:editionOf dhc:Norm_NFC14100 ;
    dhc:editionYear "2021"^^xsd:gYear ;
    dhc:shapesFile "cbox/nfc14100/nfc14100-2021.shapes.ttl" .

dhc:NormEdition_NFC15100_2002 a dhc:NormEdition ;
    rdfs:label "NF C 15-100:2002"@en ;
    rdfs:comment "Edition in force 2002–2015. Many existing installations were built under this edition."@en ;
    dhc:editionOf dhc:Norm_NFC15100 ;
    dhc:editionYear "2002"^^xsd:gYear ;
    dhc:shapesFile "cbox/nfc15100/nfc15100-2002.shapes.ttl" .

dhc:NormEdition_NFC15100_2015 a dhc:NormEdition ;
    rdfs:label "NF C 15-100:2015"@en ;
    rdfs:comment "Major revision with amended requirements for residential installations. Added requirements for IRVE, updated bathroom zones, revised minimum circuit counts."@en ;
    dhc:editionEffectiveDate "2015-11-27"^^xsd:date ;
    dhc:editionOf dhc:Norm_NFC15100 ;
    dhc:editionYear "2015"^^xsd:gYear ;
    dhc:shapesFile "cbox/nfc15100/nfc15100-2015.shapes.ttl" ;
    dhc:supersedes dhc:NormEdition_NFC15100_2002 .

dhc:NormEdition_NFC15100_2024 a dhc:NormEdition ;
    rdfs:label "NF C 15-100:2024"@en ;
    rdfs:comment "Current edition. Includes updated Part 7-702 (pools/basins), revised IRVE requirements, new requirements for energy storage systems."@en ;
    dhc:editionEffectiveDate "2024-07-01"^^xsd:date ;
    dhc:editionOf dhc:Norm_NFC15100 ;
    dhc:editionYear "2024"^^xsd:gYear ;
    dhc:shapesFile "cbox/nfc15100/nfc15100-2024.shapes.ttl" ;
    dhc:supersedes dhc:NormEdition_NFC15100_2015 .

dhc:AWSCognitoGroups a owl:DatatypeProperty ;
    rdfs:label "external ID"@en ;
    rdfs:comment "List of external groups."@en ;
    rdfs:domain dhc:User ;
    rdfs:range xsd:string .

dhc:AWSCognitoId a owl:DatatypeProperty ;
    rdfs:label "external ID"@en ;
    rdfs:comment "Link to IAM/CRM/ERP identity key (Cognito subject, SAP BP, etc.)."@en ;
    rdfs:domain dhc:User ;
    rdfs:range xsd:string .

dhc:editionEffectiveDate a owl:DatatypeProperty ;
    rdfs:label "effective date"@en ;
    rdfs:comment "Date from which this edition is enforceable for new installations."@en ;
    rdfs:domain dhc:NormEdition ;
    rdfs:range xsd:date .

dhc:editionOf a owl:ObjectProperty ;
    rdfs:label "edition of"@en ;
    rdfs:comment "Inverse of hasEdition. Links a NormEdition back to its parent Norm."@en ;
    rdfs:domain dhc:NormEdition ;
    rdfs:range dhc:Norm ;
    owl:inverseOf dhc:hasEdition .

dhc:editionYear a owl:DatatypeProperty ;
    rdfs:label "edition year"@en ;
    rdfs:comment "Publication year of this edition."@en ;
    rdfs:domain dhc:NormEdition ;
    rdfs:range xsd:gYear .

dhc:shapesFile a owl:DatatypeProperty ;
    rdfs:label "shapes file"@en ;
    rdfs:comment "Relative path to the C-Box SHACL shapes file for this edition (e.g. 'cbox/nfc15100/nfc15100-2024.shapes.ttl')."@en ;
    rdfs:domain dhc:NormEdition ;
    rdfs:range xsd:string .

dhc:supersedes a owl:ObjectProperty ;
    rdfs:label "supersedes"@en ;
    rdfs:comment "Links a NormEdition to the previous edition it replaces. Used by the compliance engine to identify the upgrade path."@en ;
    rdfs:domain dhc:NormEdition ;
    rdfs:range dhc:NormEdition .


# ════════════════════════════════════════════════════════════
# VIEW: spatial
# ════════════════════════════════════════════════════════════

dhc:Barbecue a owl:Class ;
    rdfs:label "Barbecue"@en ;
    rdfs:comment "A fixed or built-in outdoor cooking installation."@en ;
    rdfs:subClassOf dhc:OutdoorFurniture .

dhc:DetachedHouse a owl:Class ;
    rdfs:label "Detached House"@en ;
    rdfs:comment "A standalone building with four facades and no shared walls."@en ;
    rdfs:subClassOf rec:Building .

dhc:DigitalHome a owl:Class ;
    rdfs:label "Digital Home"@en ;
    rdfs:comment "The tenant boundary of a smart home digital twin. A physical property (house, apartment, land with buildings) managed as a single unit with shared IoT edge, power grid, and governance. Extends rec:Site."@en ;
    rdfs:subClassOf rec:Site .

dhc:GrandTownhouse a owl:Class ;
    rdfs:label "Grand Townhouse"@en ;
    rdfs:comment "An imposing, high-standard row house typical of Brussels, often featuring an enfilade of three rooms and a grand facade."@en ;
    rdfs:subClassOf dhc:RowHouse .

dhc:RowHouse a owl:Class ;
    rdfs:label "Row House"@en ;
    rdfs:comment "The dominant urban housing type in Brussels; a building attached on both sides, forming a continuous street front on a narrow, deep plot."@en ;
    rdfs:subClassOf rec:Building .

dhc:SemiDetachedHouse a owl:Class ;
    rdfs:label "Semi-Detached House"@en ;
    rdfs:comment "An end-of-row or paired building with three facades, sharing one sidewall."@en ;
    rdfs:subClassOf rec:Building .

dhc:createdAt a owl:DatatypeProperty ;
    rdfs:label "Created at"@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:dateTime .

dhc:createdBy a owl:ObjectProperty ;
    rdfs:label "Created by"@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range rec:Agent .

dhc:creationStatus a owl:DatatypeProperty ;
    rdfs:label "Creation status"@en ;
    rdfs:comment "One of: draft | active | archived."@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:string .

dhc:geocodeVerified a owl:DatatypeProperty ;
    rdfs:label "Geocode verified"@en ;
    rdfs:comment "True if lat/lng come from a provider geocode call."@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:boolean .

dhc:hasChargingStation a owl:ObjectProperty ;
    rdfs:label "has charging station"@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range brick:Electric_Vehicle_Charging_Station .

dhc:hasElectricVehicle a owl:ObjectProperty ;
    rdfs:label "has electric vehicle"@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range dhc:ElectricVehicle .

dhc:hasVehicle a owl:ObjectProperty ;
    rdfs:label "has vehicle"@en ;
    rdfs:comment "Links a DigitalHome to a vehicle associated with the property. Replaces dhc:hasElectricVehicle with broader scope."@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range dhc:Vehicle .

dhc:isDemo a owl:DatatypeProperty ;
    rdfs:label "Is demo"@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:boolean .

dhc:placeId a owl:DatatypeProperty ;
    rdfs:label "Place ID"@en ;
    rdfs:comment "Map provider's stable place identifier."@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:string .

dhc:placeIdProvider a owl:DatatypeProperty ;
    rdfs:label "Place ID provider"@en ;
    rdfs:comment "Provider: 'google' | 'amazon-location' | 'manual'."@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:string .

dhc:preferredLanguage a owl:DatatypeProperty ;
    rdfs:label "Preferred language"@en ;
    rdfs:comment "BCP-47 tag: 'en', 'de', 'fr'."@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:string .

dhc:smartHomeId a owl:DatatypeProperty ;
    rdfs:label "SmartHome ID"@en ;
    rdfs:comment "Tenant partition key. Format: {country}-{zip}-{street3}{number}-{nn} e.g. DE-80331-MAR12-01."@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:string .

dhc:updatedAt a owl:DatatypeProperty ;
    rdfs:label "Updated at"@en ;
    rdfs:domain dhc:DigitalHome ;
    rdfs:range xsd:dateTime .


# ════════════════════════════════════════════════════════════
