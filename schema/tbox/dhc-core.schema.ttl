@prefix dhc:   <https://digitalhome.cloud/ontology#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# ============================================================
# DigitalHome.Cloud Core Ontology — v2.2.1
#
# Multi-Box Architecture (DH-SPEC-200):
#   - T-Box (this file): norm-agnostic domain vocabulary
#   - C-Box (schema/cbox/): per-norm SHACL constraint profiles
#   - A-Box: instance data, not in this repo
#
# Norms (NF C 14-100, NF C 15-100, DIN VDE 0100, AREI/RGIE,
# BS 7671, …) are NOT encoded as subclasses here. They appear
# as dhc:Norm instances referenced from A-Box via dhc:governedBy,
# with enforceable constraints living in C-Box shape files.
#
# Design views (for the SmartHome Designer toolbox):
#   - Spatial:    RealEstate → Area → Space hierarchy
#   - Building:   Walls, windows, doors, roof, insulation
#   - Electrical: Circuits, distribution boards, protection
#   - Plumbing:   Water supply, drainage, fixtures
#   - Heating:    HVAC, radiators, heat pumps, thermostats
#   - Network:    LAN, WiFi, ZigBee, automation protocols
#   - Governance: Agents, roles, role assignments, projects
#   - Automation: Groups, scenarios, sensors, actors
#   - Compliance: Norms and governed-by relationships (v2.0.0+)
#
# v2.2.1 Refactoring (2026-04):
#   - Semantic consolidation: hasX → contains / feeds / hasPart
#   - Removed hasEquipmentType: use rdf:type instead
#   - Unified composition and containment patterns
#   - Moved brand/model/catalogRef to Equipment class
# ============================================================


# ────────────────────────────────────────────────────────────
# Ontology metadata
# ────────────────────────────────────────────────────────────

<https://digitalhome.cloud/ontology>
  a owl:Ontology ;
  rdfs:label "DigitalHome.Cloud Core Ontology"@en ;
  rdfs:label "DigitalHome.Cloud Kern-Ontologie"@de ;
  rdfs:label "Ontologie centrale DigitalHome.Cloud"@fr ;
  dcterms:description "Semantic foundation for digital twins of real estate properties. Multi-Box T-Box layer."@en ;
  owl:versionInfo "2.2.1" ;
  dcterms:creator "D-LAB-5 / DigitalHome.Cloud" ;
  dcterms:license <https://opensource.org/licenses/MIT> .


# ============================================================
# CORE SEMANTIC RELATIONS
# Unified patterns for composition, containment, and topology
# ============================================================

# Generic containment (container → contained object)
dhc:contains
  a owl:ObjectProperty ;
  rdfs:label "contains"@en ;
  rdfs:label "enthält"@de ;
  rdfs:label "contient"@fr ;
  rdfs:comment "Generic containment relation. Spatial units contain other units or equipment; systems contain components."@en ;
  dhc:designView "spatial" .

# Inverse of contains (contained object → container)
dhc:locatedIn
  a owl:ObjectProperty ;
  owl:inverseOf dhc:contains ;
  rdfs:label "located in"@en ;
  rdfs:label "befindet sich in"@de ;
  rdfs:label "situé dans"@fr ;
  rdfs:comment "Inverse of dhc:contains. Physical or logical location of a component within a container."@en ;
  dhc:designView "spatial" .

# Composition relation (assembly → part)
dhc:hasPart
  a owl:ObjectProperty ;
  rdfs:label "has part"@en ;
  rdfs:label "hat Teil"@de ;
  rdfs:label "a pour partie"@fr ;
  rdfs:comment "Composition: an assembly or system contains integral sub-components."@en ;
  dhc:designView "electrical" .

# Inverse of hasPart (part → assembly)
dhc:isPartOf
  a owl:ObjectProperty ;
  owl:inverseOf dhc:hasPart ;
  rdfs:label "is part of"@en ;
  rdfs:label "ist Teil von"@de ;
  rdfs:label "fait partie de"@fr ;
  rdfs:comment "Inverse of dhc:hasPart. Indicates component membership in an assembly."@en ;
  dhc:designView "electrical" .

# Transitive topology (upstream → downstream flow)
dhc:feeds
  a owl:ObjectProperty, owl:TransitiveProperty ;
  rdfs:label "feeds"@en ;
  rdfs:label "speist"@de ;
  rdfs:label "alimente"@fr ;
  rdfs:comment "Transitive upstream-to-downstream topology: energy, fluid, or data flows from source to destination."@en ;
  dhc:designView "electrical" .


# ============================================================
# DESIGN VIEW: Spatial
# The physical hierarchy of a property
# ============================================================

dhc:RealEstate
  a owl:Class ;
  rdfs:label "Real Estate"@en ;
  rdfs:label "Immobilie"@de ;
  rdfs:label "Bien immobilier"@fr ;
  rdfs:comment "A physical property: house, apartment, land with buildings."@en ;
  dhc:designView "spatial" .

dhc:SpatialUnit
  a owl:Class ;
  rdfs:label "Spatial Unit"@en ;
  rdfs:label "Räumliche Einheit"@de ;
  rdfs:label "Unité spatiale"@fr ;
  rdfs:comment "A generic base class for any physical or conceptual division of space within the property hierarchy (e.g., Area, Floor, Space)."@en ;
  dhc:designView "spatial" ;
  dhc:blocklyDisposition "excluded" .

dhc:Area
  a owl:Class ;
  rdfs:subClassOf dhc:SpatialUnit;
  rdfs:label "Area"@en ;
  rdfs:label "Bereich"@de ;
  rdfs:label "Zone"@fr ;
  rdfs:comment "A major subdivision of a property (e.g. main building, annex, garden)."@en ;
  dhc:designView "spatial" .

dhc:Floor
  a owl:Class ;
  rdfs:subClassOf dhc:SpatialUnit;
  rdfs:label "Floor"@en ;
  rdfs:label "Stockwerk"@de ;
  rdfs:label "Étage"@fr ;
  rdfs:comment "A storey / level within a building."@en ;
  dhc:designView "spatial" .

dhc:Space
  a owl:Class ;
  rdfs:subClassOf dhc:SpatialUnit;
  rdfs:label "Space"@en ;
  rdfs:label "Raum"@de ;
  rdfs:label "Espace"@fr ;
  rdfs:comment "A specific room or enclosed area (e.g. kitchen, bedroom, garage)."@en ;
  dhc:designView "spatial" .

dhc:Zone
  a owl:Class ;
  rdfs:label "Zone"@en ;
  rdfs:label "Zone"@de ;
  rdfs:label "Zone"@fr ;
  rdfs:comment "A logical zone spanning one or more spaces."@en ;
  dhc:designView "spatial" .

# ── Spatial data properties ──

dhc:floorLevel
  a owl:DatatypeProperty ;
  rdfs:label "floor level"@en ;
  rdfs:domain dhc:Floor ;
  rdfs:range xsd:integer ;
  rdfs:comment "Numeric level (0 = ground, -1 = basement, 1 = first, ...)."@en ;
  dhc:designView "spatial" .

dhc:height_M
  a owl:DatatypeProperty ;
  rdfs:label "Height (m)"@en ;
  rdfs:label "Höhe (m)"@de ;
  rdfs:label "Hauteur (m)"@fr ;
  rdfs:comment "The vertical height of the spatial unit measured in meters."@en ;
  rdfs:domain dhc:SpatialUnit ;
  rdfs:range xsd:decimal ;
  dhc:designView "spatial" ;
  dhc:blocklyDisposition "excluded" .

dhc:area_M2
  a owl:DatatypeProperty ;
  rdfs:label "Area (m²)"@en ;
  rdfs:label "Fläche (m²)"@de ;
  rdfs:label "Surface (m²)"@fr ;
  rdfs:domain dhc:SpatialUnit ;
  rdfs:range xsd:decimal ;
  dhc:designView "spatial" .

dhc:volume_M3
  a owl:DatatypeProperty ;
  rdfs:label "Volume (m³)"@en ;
  rdfs:label "Volumen (m³)"@de ;
  rdfs:label "Volume (m³)"@fr ;
  rdfs:domain dhc:SpatialUnit ;
  rdfs:range xsd:decimal ;
  dhc:designView "spatial" .


