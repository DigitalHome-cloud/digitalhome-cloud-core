# ============================================================
# ANNOTATION: designView
# Used by the SmartHome Designer to group classes into toolboxes
# ============================================================

dhc:designView
  a owl:AnnotationProperty ;
  rdfs:label "design view"@en ;
  rdfs:label "Entwurfsansicht"@de ;
  rdfs:label "vue de conception"@fr ;
  rdfs:comment "Indicates which Designer view/toolbox this concept belongs to. Values: spatial, building, electrical, plumbing, heating, network, governance, automation, compliance."@en .


# ============================================================
# SHARED: Common data properties
# ============================================================

dhc:name
  a owl:DatatypeProperty ;
  rdfs:label "name"@en ;
  rdfs:range xsd:string ;
  rdfs:comment "Human-readable display name for any instance."@en .

dhc:description
  a owl:DatatypeProperty ;
  rdfs:label "description"@en ;
  rdfs:range xsd:string .

