dhc:Norm_AREI_RGIE
  a dhc:Norm ;
  rdfs:label "AREI/RGIE"@en ;
  rdfs:label "AREI/RGIE"@de ;
  rdfs:label "AREI/RGIE"@fr ;
  dhc:normId "arei-rgie" ;
  dhc:normCountry "BE" ;
  dhc:normDomain "electrical" ;
  dhc:normVersion "2023" ;
  dhc:normCategory "Regulation" ;
  dhc:normWeight 1.0 ;
  rdfs:comment "General regulation on electrical installations (Belgium)."@en ;
  dhc:designView "compliance" .

dhc:Norm_BS7671
  a dhc:Norm ;
  rdfs:label "BS 7671"@en ;
  rdfs:label "BS 7671"@de ;
  rdfs:label "BS 7671"@fr ;
  dhc:normId "bs7671" ;
  dhc:normCountry "GB" ;
  dhc:normDomain "electrical" ;
  dhc:normVersion "2024" ;
  dhc:normCategory "Standard" ;
  dhc:normWeight 1.0 ;
  rdfs:comment "IET Wiring Regulations (United Kingdom)."@en ;
  dhc:designView "compliance" .


