  a owl:Class ;
  rdfs:subClassOf dhc:PlumbingSystem ;
  rdfs:label "Water Supply"@en ;
  rdfs:label "Wasserversorgung"@de ;
  rdfs:label "Alimentation en eau"@fr ;
