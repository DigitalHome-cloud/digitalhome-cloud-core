  rdfs:label "Equipment"@en ;
  rdfs:label "Gerät"@de ;
  rdfs:label "Équipement"@fr ;
  rdfs:comment "The top-level class for all physical assets in the property."@en ;
  dhc:designView "electrical" ;
  dhc:blocklyDisposition "excluded" .

dhc:EquipmentType
  a owl:Class ;
  rdfs:label "Equipment Type"@en ;
  rdfs:label "Gerätetyp"@de ;
  rdfs:label "Type d'équipement"@fr ;
  rdfs:comment "Optional ontological anchor for equipment taxonomy or catalog lookups."@en ;
  dhc:designView "electrical" ;
  dhc:blocklyDisposition "excluded" .

dhc:Assembly
