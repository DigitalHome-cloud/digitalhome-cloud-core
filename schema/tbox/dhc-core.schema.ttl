  dhc:designView "governance" .

dhc:validFrom
  a owl:DatatypeProperty ;
  rdfs:label "valid from"@en ;
  rdfs:domain dhc:RoleAssignment ;
  rdfs:range xsd:dateTime ;
  dhc:designView "governance" .

dhc:validTo
  a owl:DatatypeProperty ;
  rdfs:label "valid to"@en ;
  rdfs:domain dhc:RoleAssignment ;
  rdfs:range xsd:dateTime ;
  dhc:designView "governance" .

dhc:assignmentStatus
  a owl:DatatypeProperty ;
  rdfs:label "assignment status"@en ;
  rdfs:domain dhc:RoleAssignment ;
  rdfs:range xsd:string ;
  rdfs:comment "One of: planned, active, ended."@en ;
  dhc:designView "governance" .


# ============================================================
# DESIGN VIEW: Compliance (v2.0.0)
# Norms as first-class citizens; constraints live in C-Box
# SHACL profiles at schema/cbox/<domain>/<norm-id>.shapes.ttl
# ============================================================

dhc:Norm
  a owl:Class ;
  rdfs:label "Norm"@en ;
  rdfs:label "Norm"@de ;
  rdfs:label "Norme"@fr ;
  rdfs:comment "A national standard, regulation, or best practice. Referenced from A-Box via dhc:governedBy. Enforceable constraints live in C-Box SHACL shape files."@en ;
  dhc:designView "compliance" .

dhc:normId
  a owl:DatatypeProperty ;
  rdfs:label "norm ID"@en ;
  rdfs:label "Norm-ID"@de ;
  rdfs:label "identifiant de norme"@fr ;
  rdfs:domain dhc:Norm ;
  rdfs:range xsd:string ;
  rdfs:comment "Short stable identifier matching the C-Box file stem (e.g. 'nfc15100')."@en ;
  dhc:designView "compliance" .

dhc:normCountry
  a owl:DatatypeProperty ;
  rdfs:label "norm country"@en ;
  rdfs:label "Norm-Land"@de ;
  rdfs:label "pays de la norme"@fr ;
  rdfs:domain dhc:Norm ;
  rdfs:range xsd:string ;
  rdfs:comment "ISO 3166-1 alpha-2 country code (e.g. 'FR', 'DE', 'BE', 'GB')."@en ;
  dhc:designView "compliance" .

dhc:normDomain
  a owl:DatatypeProperty ;
  rdfs:label "norm domain"@en ;
  rdfs:label "Norm-Domäne"@de ;
  rdfs:label "domaine de la norme"@fr ;
  rdfs:domain dhc:Norm ;
  rdfs:range xsd:string ;
  rdfs:comment "Technical domain: electrical, plumbing, heating, building."@en ;
  dhc:designView "compliance" .

dhc:normVersion
  a owl:DatatypeProperty ;
  rdfs:label "norm version"@en ;
  rdfs:label "Norm-Version"@de ;
  rdfs:label "version de la norme"@fr ;
  rdfs:domain dhc:Norm ;
  rdfs:range xsd:string ;
  rdfs:comment "Norm revision year or version identifier."@en ;
  dhc:designView "compliance" .

dhc:normCategory
  a owl:DatatypeProperty ;
  rdfs:label "norm category"@en ;
  rdfs:label "Norm-Kategorie"@de ;
  rdfs:label "catégorie de norme"@fr ;
  rdfs:domain dhc:Norm ;
  rdfs:range xsd:string ;
  rdfs:comment "One of: Regulation, Standard, BestPractice."@en ;
  dhc:designView "compliance" .

dhc:normWeight
  a owl:DatatypeProperty ;
  rdfs:label "norm weight"@en ;
  rdfs:label "Norm-Gewichtung"@de ;
  rdfs:label "poids de la norme"@fr ;
  rdfs:domain dhc:Norm ;
  rdfs:range xsd:decimal ;
  rdfs:comment "1.0 = mandatory, 0.5 = recommended, 0.2 = optional."@en ;
  dhc:designView "compliance" .

dhc:governedBy
  a owl:ObjectProperty ;
  rdfs:label "governed by"@en ;
  rdfs:label "geregelt durch"@de ;
  rdfs:label "régi par"@fr ;
  rdfs:domain dhc:Circuit ;
  rdfs:range dhc:Norm ;
  rdfs:comment "Attaches a circuit (or other compliant entity) to one or more norms. Multi-valued; composability is intentional."@en ;
  dhc:designView "compliance" .


# ── Norm instances (v2.0.0) ──
# Each C-Box shape file references one of these as its
# authoritative norm via dhc:normId + dhc:governedBy.

dhc:Norm_NFC14100
  a dhc:Norm ;
  rdfs:label "NF C 14-100"@en ;
  rdfs:label "NF C 14-100"@de ;
  rdfs:label "NF C 14-100"@fr ;
  dhc:normId "nfc14100" ;
  dhc:normCountry "FR" ;
  dhc:normDomain "electrical" ;
  dhc:normVersion "2021" ;
  dhc:normCategory "Regulation" ;
  dhc:normWeight 1.0 ;
  rdfs:comment "Energy delivery from provider to main board (France)."@en ;
  dhc:designView "compliance" .

dhc:Norm_NFC15100
  a dhc:Norm ;
  rdfs:label "NF C 15-100"@en ;
  rdfs:label "NF C 15-100"@de ;
  rdfs:label "NF C 15-100"@fr ;
  dhc:normId "nfc15100" ;
  dhc:normCountry "FR" ;
  dhc:normDomain "electrical" ;
  dhc:normVersion "2024" ;
  dhc:normCategory "Regulation" ;
  dhc:normWeight 1.0 ;
  rdfs:comment "Residential electrical installation (France)."@en ;
  dhc:designView "compliance" .

dhc:Norm_DINVDE0100
  a dhc:Norm ;
  rdfs:label "DIN VDE 0100"@en ;
  rdfs:label "DIN VDE 0100"@de ;
  rdfs:label "DIN VDE 0100"@fr ;
  dhc:normId "din-vde-0100" ;
  dhc:normCountry "DE" ;
  dhc:normDomain "electrical" ;
  dhc:normVersion "2024" ;
  dhc:normCategory "Standard" ;
  dhc:normWeight 1.0 ;
  rdfs:comment "Errichten von Niederspannungsanlagen (Germany)."@en ;
