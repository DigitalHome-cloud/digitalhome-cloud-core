# ============================================================
# SHARED: Automation
# Groups, scenarios, triggers, automation rules
# ============================================================

dhc:AutomationGroup
  a owl:Class ;
  rdfs:label "Automation Group"@en ;
  rdfs:label "Automatisierungsgruppe"@de ;
  rdfs:label "Groupe d'automatisation"@fr ;
  rdfs:comment "A collection of devices or actors controlled together."@en ;
  dhc:designView "automation" .

dhc:Scenario
  a owl:Class ;
  rdfs:label "Scenario"@en ;
  rdfs:label "Szenario"@de ;
  rdfs:label "Scénario"@fr ;
  rdfs:comment "A named automation sequence or preset state."@en ;
  dhc:designView "automation" .

dhc:Trigger
  a owl:Class ;
  rdfs:label "Trigger"@en ;
  rdfs:label "Auslöser"@de ;
  rdfs:label "Déclencheur"@fr ;
  rdfs:comment "An event or condition that initiates an automation rule."@en ;
  dhc:designView "automation" .

dhc:Rule
  a owl:Class ;
  rdfs:label "Rule"@en ;
  rdfs:label "Regel"@de ;
  rdfs:label "Règle"@fr ;
  rdfs:comment "An automation rule: condition → action mapping."@en ;
  dhc:designView "automation" .

# ── Automation object properties ──

dhc:inGroup
  a owl:ObjectProperty ;
  rdfs:label "in group"@en ;
  rdfs:domain dhc:Device ;
  rdfs:range dhc:AutomationGroup ;
  dhc:designView "automation" .

dhc:triggersRule
  a owl:ObjectProperty ;
  rdfs:label "triggers rule"@en ;
  rdfs:domain dhc:Trigger ;
  rdfs:range dhc:Rule ;
  dhc:designView "automation" .

dhc:executeAction
  a owl:ObjectProperty ;
  rdfs:label "execute action"@en ;
  rdfs:domain dhc:Rule ;
  rdfs:range dhc:Actor ;
  dhc:designView "automation" .


# ============================================================
# SHARED: Governance & Compliance
# Agents, roles, role assignments, norms, constraints
# ============================================================

dhc:Agent
  a owl:Class ;
  rdfs:label "Agent"@en ;
  rdfs:label "Agent"@de ;
  rdfs:label "Agent"@fr ;
  rdfs:comment "A person, service, or system with roles and permissions."@en ;
  dhc:designView "governance" .

dhc:Role
  a owl:Class ;
  rdfs:label "Role"@en ;
  rdfs:label "Rolle"@de ;
  rdfs:label "Rôle"@fr ;
  rdfs:comment "A named permission or authority scope."@en ;
  dhc:designView "governance" .

dhc:RoleAssignment
  a owl:Class ;
  rdfs:label "Role Assignment"@en ;
  rdfs:label "Rollenzuordnung"@de ;
  rdfs:label "Attribution de rôle"@fr ;
  rdfs:comment "Association of an agent with a role in a given scope."@en ;
  dhc:designView "governance" .

dhc:Norm
  a owl:Class ;
  rdfs:label "Norm"@en ;
  rdfs:label "Norm"@de ;
  rdfs:label "Norme"@fr ;
  rdfs:comment "A regulatory or compliance standard (NF C 15-100, DIN VDE 0100, etc.)."@en ;
  dhc:designView "compliance" ;
  dhc:blocklyDisposition "excluded" .

dhc:Project
  a owl:Class ;
  rdfs:label "Project"@en ;
  rdfs:label "Projekt"@de ;
  rdfs:label "Projet"@fr ;
  rdfs:comment "A scoped collection of design and installation work."@en ;
  dhc:designView "governance" .

# ── Governance object properties ──

dhc:hasRole
  a owl:ObjectProperty ;
  rdfs:label "has role"@en ;
  rdfs:domain dhc:Agent ;
  rdfs:range dhc:RoleAssignment ;
  dhc:designView "governance" .

dhc:roleInScope
  a owl:ObjectProperty ;
  rdfs:label "role in scope"@en ;
  rdfs:domain dhc:RoleAssignment ;
  rdfs:range dhc:Role ;
  dhc:designView "governance" .

dhc:scopedTo
  a owl:ObjectProperty ;
  rdfs:label "scoped to"@en ;
  rdfs:domain dhc:RoleAssignment ;
  rdfs:range dhc:RealEstate ;
  dhc:designView "governance" .

dhc:governedBy
  a owl:ObjectProperty ;
  rdfs:label "governed by"@en ;
  rdfs:label "unterliegt"@de ;
  rdfs:label "soumis à"@fr ;
  rdfs:domain dhc:RealEstate ;
  rdfs:range dhc:Norm ;
  rdfs:comment "Regulatory compliance relationship: property is subject to norms (NF C 15-100, DIN VDE, etc.). Enforcement via C-Box SHACL constraints."@en ;
  dhc:designView "compliance" .

dhc:inProject
  a owl:ObjectProperty ;
  rdfs:label "in project"@en ;
  rdfs:domain dhc:RealEstate ;
  rdfs:range dhc:Project ;
  dhc:designView "governance" .

dhc:projectOwner
  a owl:ObjectProperty ;
  rdfs:label "project owner"@en ;
  rdfs:domain dhc:Project ;
  rdfs:range dhc:Agent ;
  dhc:designView "governance" .
