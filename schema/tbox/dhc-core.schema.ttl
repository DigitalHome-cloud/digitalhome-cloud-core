@prefix dhc:   <https://digitalhome.cloud/ontology#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# ============================================================
# DigitalHome.Cloud Core Ontology — v2.0.0
#
# Multi-Box Architecture (DH-SPEC-200):
#   - T-Box (this file): norm-agnostic domain vocabulary
#   - C-Box (schema/cbox/): per-norm SHACL constraint profiles
#   - A-Box: instance data, not in this repo
#
# Norms (NF C 14-100, NF C 15-100, DIN VDE 0100, AREI/RGIE,
# BS 7671, …) are NOT encoded as subclasses here. They appear
# as dhc:Norm instances referenced from A-Box via dhc:governedBy,
# with enforceable constraints living in C-Box shape files.
#
# Design views (for the SmartHome Designer toolbox):
#   - Spatial:    RealEstate → Area → Space hierarchy
#   - Building:   Walls, windows, doors, roof, insulation
#   - Electrical: Circuits, distribution boards, protection
#   - Plumbing:   Water supply, drainage, fixtures
#   - Heating:    HVAC, radiators, heat pumps, thermostats
#   - Network:    LAN, WiFi, ZigBee, automation protocols
#   - Governance: Agents, roles, role assignments, projects
#   - Automation: Groups, scenarios, sensors, actors
#   - Compliance: Norms and governed-by relationships (v2.0.0+)
# ============================================================


# ────────────────────────────────────────────────────────────
# Ontology metadata
# ────────────────────────────────────────────────────────────

<https://digitalhome.cloud/ontology>
  a owl:Ontology ;
  rdfs:label "DigitalHome.Cloud Core Ontology"@en ;
  rdfs:label "DigitalHome.Cloud Kern-Ontologie"@de ;
  rdfs:label "Ontologie centrale DigitalHome.Cloud"@fr ;
  dcterms:description "Semantic foundation for digital twins of real estate properties. Multi-Box T-Box layer."@en ;
  owl:versionInfo "2.0.0" ;
  dcterms:creator "D-LAB-5 / DigitalHome.Cloud" ;
  dcterms:license <https://opensource.org/licenses/MIT> .


# ============================================================
# DESIGN VIEW: Spatial
# The physical hierarchy of a property
# ============================================================

dhc:RealEstate
  a owl:Class ;
  rdfs:label "Real Estate"@en ;
  rdfs:label "Immobilie"@de ;
  rdfs:label "Bien immobilier"@fr ;
  rdfs:comment "A physical property: house, apartment, land with buildings."@en ;
  dhc:designView "spatial" .

dhc:Area
  a owl:Class ;
  rdfs:label "Area"@en ;
  rdfs:label "Bereich"@de ;
  rdfs:label "Zone"@fr ;
  rdfs:comment "A major subdivision of a property (e.g. main building, annex, garden)."@en ;
  dhc:designView "spatial" .

dhc:Floor
  a owl:Class ;
  rdfs:subClassOf dhc:Area ;
  rdfs:label "Floor"@en ;
  rdfs:label "Stockwerk"@de ;
  rdfs:label "Étage"@fr ;
  rdfs:comment "A storey / level within a building."@en ;
  dhc:designView "spatial" .

dhc:Space
  a owl:Class ;
  rdfs:label "Space"@en ;
  rdfs:label "Raum"@de ;
  rdfs:label "Espace"@fr ;
  rdfs:comment "A specific room or enclosed area (e.g. kitchen, bedroom, garage)."@en ;
  dhc:designView "spatial" .

dhc:Zone
  a owl:Class ;
  rdfs:label "Zone"@en ;
  rdfs:label "Zone"@de ;
  rdfs:label "Zone"@fr ;
  rdfs:comment "A logical zone spanning one or more spaces (e.g. thermal zone, fire compartment)."@en ;
  dhc:designView "spatial" .


# ── Spatial object properties ──

dhc:hasArea
  a owl:ObjectProperty ;
  rdfs:label "has area"@en ;
  rdfs:domain dhc:RealEstate ;
  rdfs:range dhc:Area ;
  dhc:designView "spatial" .

dhc:hasFloor
  a owl:ObjectProperty ;
  rdfs:label "has floor"@en ;
  rdfs:domain dhc:Area ;
  rdfs:range dhc:Floor ;
  dhc:designView "spatial" .

dhc:hasSpace
  a owl:ObjectProperty ;
  rdfs:label "has space"@en ;
  rdfs:domain dhc:Area ;
  rdfs:range dhc:Space ;
  dhc:designView "spatial" .

dhc:belongsToZone
  a owl:ObjectProperty ;
  rdfs:label "belongs to zone"@en ;
  rdfs:domain dhc:Space ;
  rdfs:range dhc:Zone ;
  dhc:designView "spatial" .

# ── Spatial data properties ──

dhc:floorLevel
  a owl:DatatypeProperty ;
  rdfs:label "floor level"@en ;
  rdfs:domain dhc:Floor ;
  rdfs:range xsd:integer ;
  rdfs:comment "Numeric level (0 = ground, -1 = basement, 1 = first, ...)."@en ;
  dhc:designView "spatial" .

dhc:areaM2
  a owl:DatatypeProperty ;
  rdfs:label "area (m²)"@en ;
  rdfs:domain dhc:Space ;
  rdfs:range xsd:decimal ;
  dhc:designView "spatial" .


# ============================================================
# DESIGN VIEW: Building
# Building envelope, structural elements
# ============================================================

dhc:BuildingElement
  a owl:Class ;
  rdfs:label "Building Element"@en ;
  rdfs:label "Bauelement"@de ;
  rdfs:label "Élément de construction"@fr ;
  rdfs:comment "Abstract base for structural/envelope components."@en ;
  dhc:designView "building" .

dhc:Wall
  a owl:Class ;
  rdfs:subClassOf dhc:BuildingElement ;
  rdfs:label "Wall"@en ;
  rdfs:label "Wand"@de ;
  rdfs:label "Mur"@fr ;
  dhc:designView "building" .

dhc:Window
  a owl:Class ;
  rdfs:subClassOf dhc:BuildingElement ;
  rdfs:label "Window"@en ;
  rdfs:label "Fenster"@de ;
  rdfs:label "Fenêtre"@fr ;
  dhc:designView "building" .

dhc:Door
  a owl:Class ;
  rdfs:subClassOf dhc:BuildingElement ;
  rdfs:label "Door"@en ;
  rdfs:label "Tür"@de ;
  rdfs:label "Porte"@fr ;
  dhc:designView "building" .

dhc:Roof
  a owl:Class ;
  rdfs:subClassOf dhc:BuildingElement ;
  rdfs:label "Roof"@en ;
  rdfs:label "Dach"@de ;
  rdfs:label "Toit"@fr ;
  dhc:designView "building" .

dhc:Insulation
  a owl:Class ;
  rdfs:subClassOf dhc:BuildingElement ;
  rdfs:label "Insulation"@en ;
  rdfs:label "Dämmung"@de ;
  rdfs:label "Isolation"@fr ;
  dhc:designView "building" .

# ── Building object properties ──

dhc:hasBuildingElement
  a owl:ObjectProperty ;
  rdfs:label "has building element"@en ;
  rdfs:domain dhc:Space ;
  rdfs:range dhc:BuildingElement ;
  dhc:designView "building" .

# ── Building data properties ──

dhc:uValue
  a owl:DatatypeProperty ;
  rdfs:label "U-value (W/m²K)"@en ;
  rdfs:domain dhc:BuildingElement ;
  rdfs:range xsd:decimal ;
  rdfs:comment "Thermal transmittance coefficient."@en ;
  dhc:designView "building" .

dhc:material
  a owl:DatatypeProperty ;
  rdfs:label "material"@en ;
  rdfs:domain dhc:BuildingElement ;
  rdfs:range xsd:string ;
  dhc:designView "building" .


# ============================================================
# DESIGN VIEW: Electrical
# Circuits, distribution, protection, wiring
# ============================================================

dhc:Circuit
  a owl:Class ;
  rdfs:label "Circuit"@en ;
  rdfs:label "Stromkreis"@de ;
  rdfs:label "Circuit"@fr ;
  rdfs:comment "An electrical circuit connecting equipment to a distribution board."@en ;
  dhc:designView "electrical" .

dhc:CircuitType
  a owl:Class ;
  rdfs:label "Circuit Type"@en ;
  rdfs:label "Stromkreistyp"@de ;
  rdfs:label "Type de circuit"@fr ;
  rdfs:comment "Classification: lighting, sockets, dedicated, etc."@en ;
  dhc:designView "electrical" .

dhc:DistributionBoard
  a owl:Class ;
  rdfs:label "Distribution Board"@en ;
  rdfs:label "Verteilerkasten"@de ;
  rdfs:label "Tableau électrique"@fr ;
  rdfs:comment "Main or sub distribution panel."@en ;
  dhc:designView "electrical" .

dhc:ProtectionDevice
  a owl:Class ;
  rdfs:label "Protection Device"@en ;
  rdfs:label "Schutzeinrichtung"@de ;
  rdfs:label "Dispositif de protection"@fr ;
  rdfs:comment "Circuit breaker, RCD, fuse, surge protector."@en ;
  dhc:designView "electrical" .

dhc:WiringSegment
  a owl:Class ;
  rdfs:label "Wiring Segment"@en ;
  rdfs:label "Leitungsabschnitt"@de ;
  rdfs:label "Segment de câblage"@fr ;
  rdfs:comment "A run of cable between two points."@en ;
  dhc:designView "electrical" .

dhc:ElectricalTechnicalSpace
  a owl:Class ;
  rdfs:subClassOf dhc:Space ;
  rdfs:label "Electrical Technical Space"@en ;
  rdfs:label "Elektro-Technikraum"@de ;
  rdfs:label "Espace technique électrique"@fr ;
  rdfs:comment "A generic technical space for electrical installation (e.g. GTL, electrical closet)."@en ;
  dhc:designView "electrical" .

dhc:EnergyDelivery
  a owl:Class ;
  rdfs:label "Energy Delivery"@en ;
  rdfs:label "Energieeinspeisung"@de ;
  rdfs:label "Livraison d'énergie"@fr ;
  rdfs:comment "Root entry point: contractual and physical energy supply to the property."@en ;
  dhc:designView "electrical" .

dhc:EnergyMeter
  a owl:Class ;
  rdfs:label "Energy Meter"@en ;
  rdfs:label "Stromzähler"@de ;
  rdfs:label "Compteur d'énergie"@fr ;
  rdfs:comment "A metering device measuring energy consumption."@en ;
  dhc:designView "electrical" .

dhc:EmergencyDisconnect
  a owl:Class ;
  rdfs:label "Emergency Disconnect"@en ;
  rdfs:label "Notabschaltung"@de ;
  rdfs:label "Coupure d'urgence"@fr ;
  rdfs:comment "Emergency or general disconnect device."@en ;
  dhc:designView "electrical" .

dhc:Distribution
  a owl:Class ;
  rdfs:label "Distribution"@en ;
  rdfs:label "Verteilung"@de ;
  rdfs:label "Distribution"@fr ;
  rdfs:comment "An intermediate distribution node (junction box, sub-distribution)."@en ;
  dhc:designView "electrical" .

# ── Electrical object properties ──

dhc:hasCircuit
  a owl:ObjectProperty ;
  rdfs:label "has circuit"@en ;
  rdfs:domain dhc:DistributionBoard ;
  rdfs:range dhc:Circuit ;
  dhc:designView "electrical" .

dhc:hasProtection
  a owl:ObjectProperty ;
  rdfs:label "has protection"@en ;
  rdfs:domain dhc:Circuit ;
  rdfs:range dhc:ProtectionDevice ;
  dhc:designView "electrical" .

dhc:feedsEquipment
  a owl:ObjectProperty ;
  rdfs:label "feeds equipment"@en ;
  rdfs:domain dhc:Circuit ;
  rdfs:range dhc:Equipment ;
  dhc:designView "electrical" .

dhc:hasCircuitType
  a owl:ObjectProperty ;
  rdfs:label "has circuit type"@en ;
  rdfs:domain dhc:Circuit ;
  rdfs:range dhc:CircuitType ;
  dhc:designView "electrical" .

dhc:hasWiring
  a owl:ObjectProperty ;
  rdfs:label "has wiring"@en ;
  rdfs:domain dhc:Circuit ;
  rdfs:range dhc:WiringSegment ;
  dhc:designView "electrical" .

dhc:feeds
  a owl:ObjectProperty, owl:TransitiveProperty ;
  rdfs:label "feeds"@en ;
  rdfs:label "speist"@de ;
  rdfs:label "alimente"@fr ;
  rdfs:comment "Generic upstream-to-downstream topology link in the electrical delivery chain. Transitive."@en ;
  dhc:designView "electrical" .

# R-Box: generic containment inverse, enables dhc:locatedIn owl:inverseOf dhc:contains
dhc:contains
  a owl:ObjectProperty ;
  rdfs:label "contains"@en ;
  rdfs:label "enthält"@de ;
  rdfs:label "contient"@fr ;
  rdfs:comment "Generic containment: inverse of dhc:locatedIn. A space contains devices; an area contains spaces."@en ;
  dhc:designView "spatial" .

dhc:locatedIn
  a owl:ObjectProperty ;
  owl:inverseOf dhc:contains ;
  rdfs:label "located in"@en ;
  rdfs:label "befindet sich in"@de ;
  rdfs:label "situé dans"@fr ;
  rdfs:range dhc:Space ;
  rdfs:comment "Physical location of a device or component within a space."@en ;
  dhc:designView "electrical" .

# ── Electrical data properties ──

dhc:ratedCurrent
  a owl:DatatypeProperty ;
  rdfs:label "rated current (A)"@en ;
  rdfs:label "Nennstrom (A)"@de ;
  rdfs:label "courant assigné (A)"@fr ;
  rdfs:domain dhc:ProtectionDevice ;
  rdfs:range xsd:decimal ;
  dhc:designView "electrical" .

dhc:crossSection
  a owl:DatatypeProperty ;
  rdfs:label "cross section (mm²)"@en ;
  rdfs:label "Leiterquerschnitt (mm²)"@de ;
  rdfs:label "section (mm²)"@fr ;
  rdfs:domain dhc:WiringSegment ;
  rdfs:range xsd:decimal ;
  dhc:designView "electrical" .

dhc:maxPoints
  a owl:DatatypeProperty ;
  rdfs:label "max points on circuit"@en ;
  rdfs:label "max. Punkte pro Stromkreis"@de ;
  rdfs:label "points max. par circuit"@fr ;
  rdfs:domain dhc:Circuit ;
  rdfs:range xsd:integer ;
  rdfs:comment "Maximum number of endpoints (governed by national standards via C-Box)."@en ;
  dhc:designView "electrical" .

dhc:dedicated
  a owl:DatatypeProperty ;
  rdfs:label "dedicated"@en ;
  rdfs:label "dediziert"@de ;
  rdfs:label "dédié"@fr ;
  rdfs:domain dhc:Circuit ;
  rdfs:range xsd:boolean ;
  rdfs:comment "True if this circuit is dedicated to a single appliance or kitchen/specialized zone."@en ;
  dhc:designView "electrical" .

dhc:energyProviderName
  a owl:DatatypeProperty ;
  rdfs:label "energy provider name"@en ;
  rdfs:label "Energieversorger"@de ;
  rdfs:label "fournisseur d'énergie"@fr ;
  rdfs:domain dhc:EnergyDelivery ;
  rdfs:range xsd:string ;
  dhc:designView "electrical" .

dhc:currentType
  a owl:DatatypeProperty ;
  rdfs:label "current type"@en ;
  rdfs:label "Stromart"@de ;
  rdfs:label "type de courant"@fr ;
  rdfs:domain dhc:EnergyDelivery ;
  rdfs:range xsd:string ;
  rdfs:comment "SinglePhase or ThreePhase."@en ;
  dhc:designView "electrical" .

dhc:neutralSystem
  a owl:DatatypeProperty ;
  rdfs:label "neutral system"@en ;
  rdfs:label "Erdungssystem"@de ;
  rdfs:label "régime de neutre"@fr ;
  rdfs:domain dhc:EnergyDelivery ;
  rdfs:range xsd:string ;
  rdfs:comment "Star (TT, TN-S, TN-C, IT)."@en ;
  dhc:designView "electrical" .

dhc:contractedPowerKVA
  a owl:DatatypeProperty ;
  rdfs:label "contracted power (kVA)"@en ;
  rdfs:label "Vertragsleistung (kVA)"@de ;
  rdfs:label "puissance souscrite (kVA)"@fr ;
  rdfs:domain dhc:EnergyDelivery ;
  rdfs:range xsd:decimal ;
  dhc:designView "electrical" .

dhc:phase
  a owl:DatatypeProperty ;
  rdfs:label "phase"@en ;
  rdfs:label "Phase"@de ;
  rdfs:label "phase"@fr ;
  rdfs:domain dhc:Circuit ;
  rdfs:range xsd:integer ;
  rdfs:comment "Phase count: 1 for single-phase, 3 for three-phase."@en ;
  dhc:designView "electrical" .

dhc:distributionBoardType
  a owl:DatatypeProperty ;
  rdfs:label "distribution board type"@en ;
  rdfs:label "Verteilertyp"@de ;
  rdfs:label "type de tableau"@fr ;
  rdfs:domain dhc:DistributionBoard ;
  rdfs:range xsd:string ;
  rdfs:comment "ACBoard, DCBoard, or CommunicationBoard."@en ;
  dhc:designView "electrical" .

dhc:wiring
  a owl:DatatypeProperty ;
  rdfs:label "wiring"@en ;
  rdfs:label "Verdrahtung"@de ;
  rdfs:label "câblage"@fr ;
  rdfs:range xsd:string ;
  rdfs:comment "Cable specification, e.g. 3G2.5, 5G6."@en ;
  dhc:designView "electrical" .


# ── CircuitType enum instances (v2.0.0) ──
# Universal, norm-agnostic functional categories for circuits.
# National norms (NF C 15-100, DIN VDE 0100, etc.) attach
# per-type constraints via C-Box SHACL shapes — NOT via subclasses.

dhc:CircuitType_Lighting
  a dhc:CircuitType ;
  rdfs:label "Lighting"@en ;
  rdfs:label "Beleuchtung"@de ;
  rdfs:label "Éclairage"@fr ;
  dhc:designView "electrical" .

dhc:CircuitType_Socket
  a dhc:CircuitType ;
  rdfs:label "Socket"@en ;
  rdfs:label "Steckdose"@de ;
  rdfs:label "Prise de courant"@fr ;
  dhc:designView "electrical" .

dhc:CircuitType_DedicatedAppliance
  a dhc:CircuitType ;
  rdfs:label "Dedicated Appliance"@en ;
  rdfs:label "Spezialisiertes Gerät"@de ;
  rdfs:label "Appareil spécialisé"@fr ;
  dhc:designView "electrical" .

dhc:CircuitType_Cooking
  a dhc:CircuitType ;
  rdfs:label "Cooking"@en ;
  rdfs:label "Kochen"@de ;
  rdfs:label "Cuisson"@fr ;
  dhc:designView "electrical" .

dhc:CircuitType_Heating
  a dhc:CircuitType ;
  rdfs:label "Heating"@en ;
  rdfs:label "Heizung"@de ;
  rdfs:label "Chauffage"@fr ;
  dhc:designView "electrical" .

dhc:CircuitType_WaterHeater
  a dhc:CircuitType ;
  rdfs:label "Water Heater"@en ;
  rdfs:label "Warmwasserbereiter"@de ;
  rdfs:label "Chauffe-eau"@fr ;
  dhc:designView "electrical" .

dhc:CircuitType_IRVE
  a dhc:CircuitType ;
  rdfs:label "EV Charging (IRVE)"@en ;
  rdfs:label "Elektrofahrzeug-Ladung (IRVE)"@de ;
  rdfs:label "Recharge véhicule électrique (IRVE)"@fr ;
  dhc:designView "electrical" .

dhc:CircuitType_FloorHeating
  a dhc:CircuitType ;
  rdfs:label "Floor Heating"@en ;
  rdfs:label "Fußbodenheizung"@de ;
  rdfs:label "Plancher chauffant"@fr ;
  dhc:designView "electrical" .


# ============================================================
# DESIGN VIEW: Plumbing
# Water supply, drainage, fixtures
# ============================================================

dhc:PlumbingSystem
  a owl:Class ;
  rdfs:label "Plumbing System"@en ;
  rdfs:label "Sanitärsystem"@de ;
  rdfs:label "Système de plomberie"@fr ;
  rdfs:comment "A water supply or drainage system."@en ;
  dhc:designView "plumbing" .

dhc:WaterSupply
  a owl:Class ;
  rdfs:subClassOf dhc:PlumbingSystem ;
  rdfs:label "Water Supply"@en ;
  rdfs:label "Wasserversorgung"@de ;
  rdfs:label "Alimentation en eau"@fr ;
  rdfs:comment "Cold or hot water supply network."@en ;
  dhc:designView "plumbing" .

dhc:Drainage
  a owl:Class ;
  rdfs:subClassOf dhc:PlumbingSystem ;
  rdfs:label "Drainage"@en ;
  rdfs:label "Entwässerung"@de ;
  rdfs:label "Évacuation"@fr ;
  rdfs:comment "Wastewater and rainwater drainage."@en ;
  dhc:designView "plumbing" .

dhc:PlumbingFixture
  a owl:Class ;
  rdfs:label "Plumbing Fixture"@en ;
  rdfs:label "Sanitärobjekt"@de ;
  rdfs:label "Équipement sanitaire"@fr ;
  rdfs:comment "Sink, toilet, shower, bathtub, washing machine connection."@en ;
  dhc:designView "plumbing" .

dhc:Pipe
  a owl:Class ;
  rdfs:label "Pipe"@en ;
  rdfs:label "Rohr"@de ;
  rdfs:label "Tuyau"@fr ;
  rdfs:comment "A pipe segment (copper, PER, PVC, etc.)."@en ;
