@prefix dhc:    <https://digitalhome.cloud/ontology#> .
@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix vde:    <https://digitalhome.cloud/cbox/din-vde-0100#> .

# ═══════════════════════════════════════════════════════════════════════
#  C-Box SHACL profile: DIN VDE 0100 (Germany — Low-voltage installations)
#  Binds to: dhc:Norm_DINVDE0100
#  Activation pattern: P3 sh:or guard
#  Intentional contrast with NF C 15-100: lighting rated current is 16 A
#  (not 10 A), 1.5 mm² is acceptable for 16 A sockets, and all circuits
#  must have RCD protection.
# ═══════════════════════════════════════════════════════════════════════

vde:Profile
  a owl:Ontology ;
  rdfs:label "DIN VDE 0100 C-Box profile"@en ;
  owl:versionInfo "2.0.0" ;
  dhc:normId       "din-vde-0100" ;
  dhc:normCountry  "DE" ;
  dhc:normVersion  "2018" ;
  dhc:normDomain   "electrical" .

# ── Shape 1/3: German lighting circuit (rated ≤ 16 A permitted) ─────────

vde:LightingCircuitShape_DE
  a sh:NodeShape ;
  sh:targetClass dhc:Circuit ;
  dhc:normId "din-vde-0100" ;
  rdfs:label "Lighting circuit (DIN VDE 0100)"@en ;
  sh:or (
    [ sh:not [ sh:property [ sh:path dhc:hasCircuitType ; sh:hasValue dhc:CircuitType_Lighting ] ] ]
    [
      sh:property [
        sh:path dhc:ratedCurrent ;
        sh:maxInclusive 16 ;
        dhc:defaultValue 16 ;
        sh:message "DIN VDE 0100: lighting circuit rated current ≤ 16 A."@en ;
        sh:message "DIN VDE 0100: Bemessungsstrom Lichtstromkreis ≤ 16 A."@de ;
        sh:message "DIN VDE 0100 : courant assigné du circuit d'éclairage ≤ 16 A."@fr ;
      ] ;
      sh:property [
        sh:path dhc:crossSection ;
        sh:minInclusive 1.5 ;
        dhc:defaultValue 1.5 ;
        sh:message "DIN VDE 0100: lighting circuit wire cross-section ≥ 1.5 mm²."@en ;
        sh:message "DIN VDE 0100: Aderquerschnitt Lichtstromkreis ≥ 1,5 mm²."@de ;
        sh:message "DIN VDE 0100 : section conducteurs circuit d'éclairage ≥ 1,5 mm²."@fr ;
      ]
    ]
  ) .

# ── Shape 2/3: German socket circuit (1.5 mm² allowed at 16 A) ──────────

vde:SocketCircuitShape_DE
  a sh:NodeShape ;
  sh:targetClass dhc:Circuit ;
  dhc:normId "din-vde-0100" ;
  rdfs:label "Socket circuit (DIN VDE 0100)"@en ;
  sh:or (
    [ sh:not [ sh:property [ sh:path dhc:hasCircuitType ; sh:hasValue dhc:CircuitType_Socket ] ] ]
    [ sh:not [ sh:property [ sh:path dhc:ratedCurrent ; sh:maxInclusive 16 ] ] ]
    [
      sh:property [
        sh:path dhc:crossSection ;
        sh:minInclusive 1.5 ;
        sh:message "DIN VDE 0100: socket circuit wire cross-section ≥ 1.5 mm²."@en ;
        sh:message "DIN VDE 0100: Aderquerschnitt Steckdosenstromkreis ≥ 1,5 mm²."@de ;
        sh:message "DIN VDE 0100 : section conducteurs circuit prise ≥ 1,5 mm²."@fr ;
      ] ;
      sh:property [
        sh:path dhc:maxPoints ;
        sh:maxInclusive 10 ;
        sh:message "DIN VDE 0100: socket circuit ≤ 10 sockets."@en ;
        sh:message "DIN VDE 0100: Steckdosenstromkreis ≤ 10 Steckdosen."@de ;
        sh:message "DIN VDE 0100 : circuit prise ≤ 10 socles."@fr ;
      ]
    ]
  ) .

# ── Shape 3/3: RCD coverage — every circuit needs protection ────────────

vde:RCDCoverageShape_DE
  a sh:NodeShape ;
  sh:targetClass dhc:Circuit ;
  dhc:normId "din-vde-0100" ;
  rdfs:label "Every circuit must have at least one ProtectionDevice"@en ;
  sh:property [
    sh:path dhc:hasProtection ;
    sh:minCount 1 ;
    sh:class dhc:ProtectionDevice ;
    sh:message "DIN VDE 0100: every Circuit must have at least one RCD/ProtectionDevice."@en ;
    sh:message "DIN VDE 0100: jeder Stromkreis muss mindestens einen FI/RCD besitzen."@de ;
    sh:message "DIN VDE 0100 : chaque circuit doit disposer d'au moins un dispositif de protection (DDR)."@fr ;
  ] .
