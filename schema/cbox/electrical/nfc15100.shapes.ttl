@prefix dhc:     <https://digitalhome.cloud/ontology#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix nfc15100: <https://digitalhome.cloud/cbox/nfc15100#> .

# ═══════════════════════════════════════════════════════════════════════
#  C-Box SHACL profile: NF C 15-100 (France — Low-voltage installations)
#  Binds to: dhc:Norm_NFC15100
#  Activation pattern: P3 sh:or guard (rdf-validate-shacl@0.6.0 compatible)
#  See repos/core/CLAUDE.md § SHACL activation pattern.
# ═══════════════════════════════════════════════════════════════════════

nfc15100:Profile
  a owl:Ontology ;
  rdfs:label "NF C 15-100 C-Box profile"@en ;
  rdfs:label "NF C 15-100 C-Box-Profil"@de ;
  rdfs:label "Profil C-Box NF C 15-100"@fr ;
  owl:versionInfo "2.0.0" ;
  dhc:normId       "nfc15100" ;
  dhc:normCountry  "FR" ;
  dhc:normVersion  "2015-A5" ;
  dhc:normDomain   "electrical" .

# ── Shape 1/22: Lighting circuit ────────────────────────────────────────

nfc15100:LightingCircuitShape
  a sh:NodeShape ;
  sh:targetClass dhc:Circuit ;
  dhc:normId "nfc15100" ;
  rdfs:label "Lighting circuit (NF C 15-100)"@en ;
  rdfs:label "Lichtstromkreis (NF C 15-100)"@de ;
  rdfs:label "Circuit d'éclairage (NF C 15-100)"@fr ;
  sh:or (
    [ sh:not [ sh:property [ sh:path dhc:hasCircuitType ; sh:hasValue dhc:CircuitType_Lighting ] ] ]
    [
      sh:property [
        sh:path dhc:maxPoints ;
        sh:maxInclusive 8 ;
        dhc:defaultValue 8 ;
        sh:message "NF C 15-100: lighting circuit must not exceed 8 points."@en ;
        sh:message "NF C 15-100: Lichtstromkreis darf höchstens 8 Punkte haben."@de ;
        sh:message "NF C 15-100 : un circuit d'éclairage ne doit pas dépasser 8 points."@fr ;
      ] ;
      sh:property [
        sh:path dhc:ratedCurrent ;
        sh:maxInclusive 16 ;
        dhc:defaultValue 10 ;
        sh:message "NF C 15-100: lighting circuit rated current must be ≤ 16 A."@en ;
        sh:message "NF C 15-100: Bemessungsstrom Lichtstromkreis ≤ 16 A."@de ;
        sh:message "NF C 15-100 : courant assigné du circuit d'éclairage ≤ 16 A."@fr ;
      ] ;
      sh:property [
        sh:path dhc:crossSection ;
        sh:minInclusive 1.5 ;
        dhc:defaultValue 1.5 ;
        sh:message "NF C 15-100: lighting circuit wire cross-section must be ≥ 1.5 mm²."@en ;
        sh:message "NF C 15-100: Aderquerschnitt Lichtstromkreis ≥ 1,5 mm²."@de ;
        sh:message "NF C 15-100 : section des conducteurs du circuit d'éclairage ≥ 1,5 mm²."@fr ;
      ]
    ]
  ) .

# ── Shape 2/22: Socket 16 A (non-dedicated) ─────────────────────────────

nfc15100:SocketCircuit16AShape
  a sh:NodeShape ;
  sh:targetClass dhc:Circuit ;
  dhc:normId "nfc15100" ;
  rdfs:label "Socket circuit 16 A (NF C 15-100)"@en ;
  sh:or (
    [ sh:not [ sh:property [ sh:path dhc:hasCircuitType ; sh:hasValue dhc:CircuitType_Socket ] ] ]
    [ sh:not [ sh:property [ sh:path dhc:ratedCurrent ; sh:maxInclusive 16 ] ] ]
    [ sh:property [ sh:path dhc:dedicated ; sh:hasValue true ] ]
    [
      sh:property [
        sh:path dhc:maxPoints ;
        sh:maxInclusive 8 ;
        dhc:defaultValue 8 ;
        sh:message "NF C 15-100: 16 A socket circuit must not exceed 8 sockets."@en ;
        sh:message "NF C 15-100: 16-A-Steckdosenstromkreis darf höchstens 8 Steckdosen haben."@de ;
        sh:message "NF C 15-100 : circuit prise 16 A ≤ 8 socles."@fr ;
      ] ;
      sh:property [
        sh:path dhc:crossSection ;
        sh:minInclusive 1.5 ;
        dhc:defaultValue 2.5 ;
        sh:message "NF C 15-100: 16 A socket circuit wire cross-section ≥ 1.5 mm²."@en ;
        sh:message "NF C 15-100: Aderquerschnitt 16-A-Steckdosenstromkreis ≥ 1,5 mm²."@de ;
        sh:message "NF C 15-100 : section conducteurs circuit prise 16 A ≥ 1,5 mm²."@fr ;
      ]
    ]
  ) .

# ── Shape 3/22: Socket 20 A (non-dedicated) ─────────────────────────────

nfc15100:SocketCircuit20AShape
  a sh:NodeShape ;
  sh:targetClass dhc:Circuit ;
  dhc:normId "nfc15100" ;
  rdfs:label "Socket circuit 20 A (NF C 15-100)"@en ;
  sh:or (
    [ sh:not [ sh:property [ sh:path dhc:hasCircuitType ; sh:hasValue dhc:CircuitType_Socket ] ] ]
    [ sh:not [ sh:property [ sh:path dhc:ratedCurrent ; sh:minExclusive 16 ] ] ]
    [ sh:not [ sh:property [ sh:path dhc:ratedCurrent ; sh:maxInclusive 20 ] ] ]
    [ sh:property [ sh:path dhc:dedicated ; sh:hasValue true ] ]
    [
      sh:property [
        sh:path dhc:maxPoints ;
        sh:maxInclusive 12 ;
        dhc:defaultValue 12 ;
        sh:message "NF C 15-100: 20 A socket circuit must not exceed 12 sockets."@en ;
        sh:message "NF C 15-100: 20-A-Steckdosenstromkreis darf höchstens 12 Steckdosen haben."@de ;
        sh:message "NF C 15-100 : circuit prise 20 A ≤ 12 socles."@fr ;
      ] ;
      sh:property [
        sh:path dhc:crossSection ;
        sh:minInclusive 2.5 ;
        dhc:defaultValue 2.5 ;
        sh:message "NF C 15-100: 20 A socket circuit wire cross-section ≥ 2.5 mm²."@en ;
        sh:message "NF C 15-100: Aderquerschnitt 20-A-Steckdosenstromkreis ≥ 2,5 mm²."@de ;
        sh:message "NF C 15-100 : section conducteurs circuit prise 20 A ≥ 2,5 mm²."@fr ;
      ]
    ]
  ) .

# ── Shape 4/22: Kitchen / dedicated socket circuit ──────────────────────

nfc15100:KitchenSocketCircuitShape
  a sh:NodeShape ;
  sh:targetClass dhc:Circuit ;
  dhc:normId "nfc15100" ;
  rdfs:label "Kitchen (dedicated) socket circuit (NF C 15-100)"@en ;
  sh:or (
    [ sh:not [ sh:property [ sh:path dhc:hasCircuitType ; sh:hasValue dhc:CircuitType_Socket ] ] ]
    [ sh:not [ sh:property [ sh:path dhc:dedicated ; sh:hasValue true ] ] ]
    [ sh:not [ sh:property [ sh:path dhc:ratedCurrent ; sh:maxInclusive 20 ] ] ]
    [
      sh:property [
        sh:path dhc:maxPoints ;
        sh:maxInclusive 6 ;
        dhc:defaultValue 6 ;
        sh:message "NF C 15-100: dedicated kitchen socket circuit ≤ 6 sockets."@en ;
        sh:message "NF C 15-100: Dedizierter Küchen-Steckdosenstromkreis ≤ 6 Steckdosen."@de ;
        sh:message "NF C 15-100 : circuit prise dédié cuisine ≤ 6 socles."@fr ;
      ] ;
      sh:property [
        sh:path dhc:crossSection ;
        sh:minInclusive 2.5 ;
        dhc:defaultValue 2.5 ;
        sh:message "NF C 15-100: dedicated kitchen socket wire cross-section ≥ 2.5 mm²."@en ;
        sh:message "NF C 15-100: Querschnitt dedizierter Küchenstromkreis ≥ 2,5 mm²."@de ;
        sh:message "NF C 15-100 : section conducteurs circuit prise dédié ≥ 2,5 mm²."@fr ;
      ]
    ]
  ) .

# ── Shape 5/22: Specialized dedicated appliance circuit ─────────────────

nfc15100:SpecializedApplianceShape
  a sh:NodeShape ;
  sh:targetClass dhc:Circuit ;
  dhc:normId "nfc15100" ;
  rdfs:label "Specialized appliance circuit (NF C 15-100)"@en ;
  sh:or (
    [ sh:not [ sh:property [ sh:path dhc:hasCircuitType ; sh:hasValue dhc:CircuitType_DedicatedAppliance ] ] ]
    [
      sh:property [
        sh:path dhc:maxPoints ;
        sh:maxInclusive 1 ;
        sh:message "NF C 15-100: specialized-appliance circuit must serve exactly one point."@en ;
        sh:message "NF C 15-100: Spezialgerätestromkreis darf nur einen Punkt versorgen."@de ;
        sh:message "NF C 15-100 : circuit spécialisé doit alimenter un seul point."@fr ;
      ] ;
      sh:property [
        sh:path dhc:ratedCurrent ;
        sh:maxInclusive 20 ;
        sh:message "NF C 15-100: specialized-appliance rated current ≤ 20 A."@en ;
        sh:message "NF C 15-100: Bemessungsstrom Spezialgerät ≤ 20 A."@de ;
        sh:message "NF C 15-100 : courant assigné circuit spécialisé ≤ 20 A."@fr ;
      ] ;
      sh:property [
        sh:path dhc:crossSection ;
        sh:minInclusive 2.5 ;
        sh:message "NF C 15-100: specialized-appliance wire cross-section ≥ 2.5 mm²."@en ;
        sh:message "NF C 15-100: Aderquerschnitt Spezialgerät ≥ 2,5 mm²."@de ;
        sh:message "NF C 15-100 : section conducteurs circuit spécialisé ≥ 2,5 mm²."@fr ;
      ]
    ]
  ) .

