# ── Shape 7/22: Cooking — single-phase ──────────────────────────────────

nfc15100:CookingMonoShape
  a sh:NodeShape ;
  sh:targetClass dhc:Circuit ;
  dhc:normId "nfc15100" ;
  rdfs:label "Single-phase cooking circuit (NF C 15-100)"@en ;
  sh:or (
    [ sh:not [ sh:property [ sh:path dhc:hasCircuitType ; sh:hasValue dhc:CircuitType_Cooking ] ] ]
    [ sh:not [ sh:property [ sh:path dhc:phase ; sh:hasValue 1 ] ] ]
    [
      sh:property [
        sh:path dhc:maxPoints ;
        sh:maxInclusive 1 ;
        sh:message "NF C 15-100: cooking circuit serves a single point."@en ;
        sh:message "NF C 15-100: Kochstromkreis nur ein Punkt."@de ;
        sh:message "NF C 15-100 : circuit cuisson — un seul point."@fr ;
      ] ;
      sh:property [
        sh:path dhc:ratedCurrent ;
        sh:maxInclusive 32 ;
        sh:message "NF C 15-100: single-phase cooking rated current ≤ 32 A."@en ;
        sh:message "NF C 15-100: Bemessungsstrom Kochen 1-phasig ≤ 32 A."@de ;
        sh:message "NF C 15-100 : courant assigné cuisson monophasé ≤ 32 A."@fr ;
      ] ;
      sh:property [
        sh:path dhc:crossSection ;
        sh:minInclusive 6.0 ;
        sh:message "NF C 15-100: single-phase cooking wire cross-section ≥ 6 mm²."@en ;
        sh:message "NF C 15-100: Aderquerschnitt Kochen 1-phasig ≥ 6 mm²."@de ;
        sh:message "NF C 15-100 : section conducteurs cuisson monophasé ≥ 6 mm²."@fr ;
      ]
    ]
  ) .

