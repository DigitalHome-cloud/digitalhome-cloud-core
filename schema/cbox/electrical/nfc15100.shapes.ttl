    ]
  ) .

# ── Shapes 18–20/22: IRVE (EV charging station circuits) ────────────────

nfc15100:IRVE16AShape
  a sh:NodeShape ;
  sh:targetClass dhc:Circuit ;
  dhc:normId "nfc15100" ;
  rdfs:label "IRVE EV charging — 16 A (NF C 15-100)"@en ;
  sh:or (
    [ sh:not [ sh:property [ sh:path dhc:hasCircuitType ; sh:hasValue dhc:CircuitType_IRVE ] ] ]
    [ sh:not [ sh:property [ sh:path dhc:ratedCurrent ; sh:maxInclusive 16 ] ] ]
    [ sh:property [
        sh:path dhc:crossSection ;
        sh:minInclusive 2.5 ;
        sh:message "NF C 15-100: IRVE 16 A — cross-section ≥ 2.5 mm²."@en ;
        sh:message "NF C 15-100: IRVE 16 A — Querschnitt ≥ 2,5 mm²."@de ;
        sh:message "NF C 15-100 : IRVE 16 A — section ≥ 2,5 mm²."@fr ;
      ] ]
  ) .

nfc15100:IRVE32AMonoShape
  a sh:NodeShape ;
  sh:targetClass dhc:Circuit ;
  dhc:normId "nfc15100" ;
  rdfs:label "IRVE EV charging — 32 A single-phase (NF C 15-100)"@en ;
  sh:or (
    [ sh:not [ sh:property [ sh:path dhc:hasCircuitType ; sh:hasValue dhc:CircuitType_IRVE ] ] ]
    [ sh:not [ sh:property [ sh:path dhc:ratedCurrent ; sh:hasValue 32 ] ] ]
    [ sh:not [ sh:property [ sh:path dhc:phase ; sh:hasValue 1 ] ] ]
    [ sh:property [
        sh:path dhc:crossSection ;
        sh:minInclusive 10.0 ;
        sh:message "NF C 15-100: IRVE 32 A single-phase — cross-section ≥ 10 mm²."@en ;
        sh:message "NF C 15-100: IRVE 32 A einphasig — Querschnitt ≥ 10 mm²."@de ;
        sh:message "NF C 15-100 : IRVE 32 A monophasé — section ≥ 10 mm²."@fr ;
      ] ]
  ) .

nfc15100:IRVE32ATriShape
  a sh:NodeShape ;
  sh:targetClass dhc:Circuit ;
  dhc:normId "nfc15100" ;
  rdfs:label "IRVE EV charging — 32 A three-phase (NF C 15-100)"@en ;
  sh:or (
    [ sh:not [ sh:property [ sh:path dhc:hasCircuitType ; sh:hasValue dhc:CircuitType_IRVE ] ] ]
    [ sh:not [ sh:property [ sh:path dhc:ratedCurrent ; sh:hasValue 32 ] ] ]
    [ sh:not [ sh:property [ sh:path dhc:phase ; sh:hasValue 3 ] ] ]
    [ sh:property [
        sh:path dhc:crossSection ;
        sh:minInclusive 6.0 ;
        sh:message "NF C 15-100: IRVE 32 A three-phase — cross-section ≥ 6 mm²."@en ;
        sh:message "NF C 15-100: IRVE 32 A dreiphasig — Querschnitt ≥ 6 mm²."@de ;
        sh:message "NF C 15-100 : IRVE 32 A triphasé — section ≥ 6 mm²."@fr ;
      ] ]
  ) .

# ── Shape 21/22: GTL — electrical technical space must colocate a board ─

nfc15100:GTLShape
  a sh:NodeShape ;
  sh:targetClass dhc:ElectricalTechnicalSpace ;
  dhc:normId "nfc15100" ;
  rdfs:label "GTL — electrical technical space houses ≥1 DistributionBoard"@en ;
  sh:property [
    sh:path dhc:contains ;
    sh:qualifiedValueShape [ sh:class dhc:DistributionBoard ] ;
    sh:qualifiedMinCount 1 ;
    sh:message "NF C 15-100: GTL (electrical technical space) must contain at least one DistributionBoard."@en ;
    sh:message "NF C 15-100: GTL (Elektro-Technikraum) muss mindestens einen Verteilerkasten enthalten."@de ;
    sh:message "NF C 15-100 : la GTL doit contenir au moins un tableau électrique."@fr ;
  ] .

# ── Shape 22/22: Every Circuit must be governed by at least one norm ────

nfc15100:NormGovernanceShape
  a sh:NodeShape ;
  sh:targetClass dhc:Circuit ;
  dhc:normId "nfc15100" ;
  rdfs:label "Every Circuit must declare at least one governing norm"@en ;
  sh:property [
    sh:path dhc:governedBy ;
    sh:minCount 1 ;
    sh:class dhc:Norm ;
    sh:message "Every Circuit must reference at least one dhc:Norm via dhc:governedBy."@en ;
    sh:message "Jeder Stromkreis muss über dhc:governedBy mindestens eine dhc:Norm referenzieren."@de ;
    sh:message "Chaque circuit doit référencer au moins une dhc:Norm via dhc:governedBy."@fr ;
  ] .
