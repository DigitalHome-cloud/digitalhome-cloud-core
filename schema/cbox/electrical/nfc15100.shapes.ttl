        sh:message "NF C 15-100 : courant assigné cuisson triphasé ≤ 20 A par phase."@fr ;
      ] ;
      sh:property [
        sh:path dhc:crossSection ;
        sh:minInclusive 2.5 ;
        sh:message "NF C 15-100: three-phase cooking wire cross-section ≥ 2.5 mm² (5G2.5)."@en ;
        sh:message "NF C 15-100: Aderquerschnitt Kochen 3-phasig ≥ 2,5 mm² (5G2,5)."@de ;
        sh:message "NF C 15-100 : section conducteurs cuisson triphasé ≥ 2,5 mm² (5G2,5)."@fr ;
      ]
    ]
  ) .

